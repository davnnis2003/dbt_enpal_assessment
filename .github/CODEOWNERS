# GitHub CODEOWNERS File
# Ref: https://docs.github.com/en/repositories/managing-your-repositorys-settings-and-features/customizing-your-repository/about-codeowners

# Each line is a pattern followed by one or more owners.
# Owners can be GitHub usernames (@username) or teams within an organization (@org/team-name).

# -------------------------------------------------------------
# Global Ownership
# -------------------------------------------------------------
# Default owners for all files in the repository (unless overridden below).
*                                       @central-data-team

# -------------------------------------------------------------
# Core Infrastructure & Configuration
# -------------------------------------------------------------
# Database configuration, package locks, and dependencies are owned by the Data Platform / Platform Engineering team.
/dbt_project.yml                        @data-platform-admin @central-data-team
/packages.yml                           @data-platform-admin @central-data-team
/profiles.yml                           @data-platform-admin
/docker-compose.yml                     @data-platform-admin
/init.sql                               @data-platform-admin
/pyproject.toml                         @data-platform-admin
/uv.lock                                @data-platform-admin
/.sqlfluff                              @data-platform-admin @central-data-team

# -------------------------------------------------------------
# Data Ingestion & Staging Layer (ODS)
# -------------------------------------------------------------
# Staging models correspond 1:1 with source schemas and are managed by the Central Data team to ensure clean base layers.
/models/staging/                        @central-data-team @data-platform-admin
/seeds/                                 @central-data-team

# -------------------------------------------------------------
# Marts & Shared Dimensions/Facts
# -------------------------------------------------------------
# Core dimensional models (e.g., users, field options, stages) and fact models (activities, deal changes)
# are co-owned by Central Data and Analytics Engineers.
/models/marts/                          @central-data-team @analytics-engineering-team
/macros/                                @central-data-team @analytics-engineering-team

# -------------------------------------------------------------
# Reporting & Business Unit Domain Models (Decentralized)
# -------------------------------------------------------------
# Reporting models (BI-ready aggregates) and exposures are managed by team-specific domain analysts.
# For example, Sales Analytics owns the CRM and sales funnel reports.
/models/reporting/                      @analytics-engineering-team @sales-analytics-team
/models/exposures.yml                   @analytics-engineering-team @sales-analytics-team
/analyses/                              @analytics-engineering-team @sales-analytics-team
